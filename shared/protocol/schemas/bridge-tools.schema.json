{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://abyss.dev/schemas/bridge-tools.schema.json",
  "title": "Bridge Tool Call Payloads",
  "type": "object",
  "properties": {
    "bridge.exec.run.args": {
      "type": "object",
      "required": ["command"],
      "properties": {
        "deviceId": { "type": "string" },
        "command": { "type": "string", "minLength": 1 },
        "cwd": { "type": "string" },
        "timeoutSec": { "type": "number", "minimum": 1, "maximum": 600 }
      },
      "additionalProperties": false
    },
    "bridge.exec.run.result": {
      "type": "object",
      "required": ["exitCode", "stdout", "stderr"],
      "properties": {
        "exitCode": { "type": "integer" },
        "stdout": { "type": "string" },
        "stderr": { "type": "string" }
      },
      "additionalProperties": false
    },
    "bridge.fs.readFile.args": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "deviceId": { "type": "string" },
        "path": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "bridge.fs.readFile.result": {
      "type": "object",
      "required": ["content"],
      "properties": {
        "content": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
